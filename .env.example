# ─── Raptor AI Environment Configuration ─────────────
# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# ─── Required ─────────────────────────────────────────
GROQ_API_KEY=

# ─── Optional: External Intelligence APIs ─────────────
OPENWEATHER_API_KEY=
NEWS_API_KEY=
SPORTS_API_KEY=

# ─── Optional: Google Services ────────────────────────
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Optional: Cloud LLM Providers ───────────────────
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# ─── Feature Flags ───────────────────────────────────
EMAIL_ENABLED=false
BROWSER_BRIDGE_ENABLED=true
PROACTIVE_MONITOR_ENABLED=true
