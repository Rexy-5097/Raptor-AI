{
  "manifest_version": 3,
  "name": "Raptor Browser Bridge",
  "version": "1.0.0",
  "description": "Browser intelligence layer for Raptor AI — reads and controls active tabs",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/raptor16.png",
    "48": "icons/raptor48.png",
    "128": "icons/raptor128.png"
  }
}
